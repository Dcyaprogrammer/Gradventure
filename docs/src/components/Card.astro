---
interface Props {
	title: string;
	body: string;
	href?: string;
    icon?: string;
}

const { href, title, body, icon } = Astro.props;
---

<div class="card group h-full flex flex-col justify-between relative bg-white">
    <div>
        {icon && <div class="text-5xl mb-6 transition-transform group-hover:scale-110 group-hover:translate-x-2 group-hover:rotate-6 duration-200 origin-bottom-left">{icon}</div>}
        <h3 class="text-3xl font-black mb-4 font-display uppercase leading-none border-b-4 border-transparent group-hover:border-black inline-block transition-colors">
            {title}
        </h3>
        <p class="text-black font-bold mt-2 text-base leading-relaxed border-t-4 border-black pt-4">
            {body}
        </p>
    </div>
    {href && (
        <a href={href} class="absolute inset-0 z-10" aria-label={`Link to ${title}`}></a>
    )}
</div>
