---
interface Props {
    title: string;
    subtitle: string;
    tag?: string;
    primaryAction?: { text: string; href: string };
    secondaryAction?: { text: string; href: string };
}

const { title, subtitle, tag, primaryAction, secondaryAction } = Astro.props;
---

<section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden border-b-4 border-black bg-brand-yellow">
    <!-- Base Grid Pattern -->
    <div class="absolute inset-0 bg-grid-pattern pointer-events-none"></div>
    
    <!-- Neo-Brutalism Decorations -->
    <div class="absolute inset-0 pointer-events-none select-none overflow-hidden">
        <!-- Giant Star -->
        <svg class="absolute -right-20 top-10 h-[400px] w-[400px] text-brand-pink drop-shadow-[8px_8px_0px_rgba(0,0,0,1)] animate-[spin_20s_linear_infinite]" viewBox="0 0 24 24" fill="currentColor" stroke="black" stroke-width="1">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
        </svg>

        <!-- Thick Vertical Line -->
        <div class="absolute left-10 top-0 bottom-0 w-[4px] bg-black hidden md:block"></div>
        
        <!-- Random Bold Plus Signs -->
        <div class="absolute top-32 left-8 text-black font-black text-2xl hidden md:block">+</div>
        <div class="absolute bottom-20 right-10 text-black font-black text-4xl">+</div>
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10 flex flex-col justify-center min-h-[50vh]">
        {tag && (
            <div class="inline-block self-start border-4 border-black bg-brand-cyan px-4 py-2 mb-8 text-sm font-bold text-black tracking-widest uppercase shadow-neo transform -rotate-2">
                {tag}
            </div>
        )}
        <h1 class="text-6xl md:text-8xl lg:text-[140px] font-black tracking-tighter mb-6 leading-[0.9] text-white font-display uppercase drop-shadow-[6px_6px_0px_rgba(0,0,0,1)]" style="-webkit-text-stroke: 2px black;">
            {title}
        </h1>
        <p class="text-xl md:text-2xl text-black font-bold max-w-3xl leading-relaxed mb-12 bg-white border-4 border-black p-6 shadow-neo inline-block transform rotate-1">
            {subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-6">
            {primaryAction && (
                <a href={primaryAction.href} class="btn bg-brand-accent text-white hover:bg-white hover:text-black text-lg px-10 py-5 text-xl">
                    {primaryAction.text}
                </a>
            )}
            {secondaryAction && (
                <a href={secondaryAction.href} class="btn bg-brand-pink text-black hover:bg-white text-lg px-10 py-5 text-xl">
                    {secondaryAction.text}
                </a>
            )}
        </div>
    </div>
</section>
