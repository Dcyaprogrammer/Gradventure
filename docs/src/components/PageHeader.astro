---
interface Props {
    title: string;
    subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="pt-32 pb-16 md:pt-40 md:pb-20 border-b-4 border-black bg-brand-cyan relative overflow-hidden">
    <div class="absolute inset-0 bg-grid-pattern pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <h1 class="text-5xl md:text-7xl font-black mb-6 font-display uppercase tracking-tight text-black drop-shadow-[4px_4px_0px_rgba(255,255,255,1)]">
            {title}
        </h1>
        <p class="text-xl md:text-2xl text-black font-bold max-w-3xl leading-relaxed bg-white border-3 border-black p-4 shadow-neo inline-block">
            {subtitle}
        </p>
    </div>
</div>
