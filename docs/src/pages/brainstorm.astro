---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
---

<Layout title="Brainstorming | HCI Portfolio">
    <PageHeader 
        title="Brainstorming" 
        subtitle="Exploring the problem space and generating initial concepts."
    />

    <Section title="Problem Space">
        <p class="text-lg text-neutral-300 mb-8 max-w-3xl">
            Students face significant challenges when preparing for study abroad. The process is often overwhelming, with information scattered across multiple sources.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="card bg-neutral-900/50">
                <h3 class="font-bold text-white mb-2">Information Overload</h3>
                <p class="text-neutral-400 text-sm">Too many sources with conflicting information.</p>
            </div>
            <div class="card bg-neutral-900/50">
                <h3 class="font-bold text-white mb-2">Lack of Engagement</h3>
                <p class="text-neutral-400 text-sm">Traditional guides are dry and unmotivating.</p>
            </div>
            <div class="card bg-neutral-900/50">
                <h3 class="font-bold text-white mb-2">Complex Process</h3>
                <p class="text-neutral-400 text-sm">Multi-step procedures that are hard to track.</p>
            </div>
        </div>
    </Section>

    <Section title="Ideation" class="bg-neutral-900/20 border-t border-b border-neutral-800">
        <!-- Visual Materials -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            <div class="aspect-video bg-neutral-800 border border-neutral-700 flex items-center justify-center">
                <span class="font-mono text-neutral-500">MINDMAP.png</span>
            </div>
            <div class="aspect-video bg-neutral-800 border border-neutral-700 flex items-center justify-center">
                <span class="font-mono text-neutral-500">SKETCHES.png</span>
            </div>
        </div>

        <!-- Stakeholder Interview -->
        <div class="border-l-4 border-brand-accent pl-6 bg-bg-dark p-6">
            <div class="flex items-center gap-3 mb-4">
                <span class="text-2xl">💬</span>
                <h3 class="text-xl font-bold text-white">Stakeholder Consultation</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Left: Interview Details -->
                <div>
                    <div class="mb-4">
                        <span class="text-neutral-500 font-mono text-sm">// WHO</span>
                        <p class="text-white mt-1">SAT Course Instructor</p>
                    </div>
                    <div>
                        <span class="text-neutral-500 font-mono text-sm">// TOPIC</span>
                        <p class="text-white mt-1">Feasibility discussion and gamification strategy</p>
                    </div>
                </div>

                <!-- Right: Key Finding -->
                <div class="bg-bg-darker border border-brand-accent/30 p-4">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="text-brand-accent">✦</span>
                        <span class="text-brand-accent font-mono text-sm font-semibold">KEY CONCEPT</span>
                    </div>
                    <p class="text-white text-lg font-semibold mb-3">
                        🎯 Level-Based Quiz System
                    </p>
                    <p class="text-neutral-400 text-sm leading-relaxed">
                        Progressive difficulty levels with reward unlocking mechanism.
                        Players earn points through quiz challenges and unlock new content/rewards upon reaching score thresholds.
                    </p>
                </div>
            </div>
        </div>
    </Section>
</Layout>
