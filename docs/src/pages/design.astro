---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
---

<Layout title="HCI Portfolio | UI Design Journey">
    <PageHeader 
        title="UI Design Journey" 
        description="The evolution of our visual language, wireframes, and design iterations."
    />

    <Section title="Design Iterations">
        <div class="mb-12 bg-white p-6 border-4 border-black shadow-neo inline-block transform -rotate-1">
            <p class="text-black text-xl font-bold leading-relaxed">
                Documenting how our initial concepts transformed into high-fidelity interfaces through iterative design cycles.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-16">
            <div class="bg-brand-pink border-4 border-black p-8 shadow-neo-lg transform rotate-1 hover:rotate-0 transition-transform">
                <h3 class="text-3xl font-black text-black mb-6 font-display uppercase border-b-4 border-black pb-2 inline-block">Low-Fidelity Wireframes</h3>
                <div class="aspect-video bg-white border-4 border-black flex items-center justify-center relative overflow-hidden group w-full mb-6 shadow-neo hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-neo-none transition-all cursor-pointer">
                    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
                    <span class="font-mono font-bold text-black text-xl bg-brand-yellow px-4 py-2 border-4 border-black group-hover:bg-brand-cyan transition-colors transform -rotate-2">WIREFRAMES.img</span>
                </div>
                <p class="text-black font-bold text-lg bg-white border-2 border-black p-2 inline-block shadow-neo">Initial structure and information architecture planning.</p>
            </div>

            <div class="bg-brand-cyan border-4 border-black p-8 shadow-neo-lg transform -rotate-1 hover:rotate-0 transition-transform">
                <h3 class="text-3xl font-black text-black mb-6 font-display uppercase border-b-4 border-black pb-2 inline-block">Mid-Fidelity Designs</h3>
                <div class="aspect-video bg-white border-4 border-black flex items-center justify-center relative overflow-hidden group w-full mb-6 shadow-neo hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-neo-none transition-all cursor-pointer">
                    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
                    <span class="font-mono font-bold text-black text-xl bg-brand-pink px-4 py-2 border-4 border-black group-hover:bg-brand-yellow transition-colors transform rotate-2">MID_FI.img</span>
                </div>
                <p class="text-black font-bold text-lg bg-white border-2 border-black p-2 inline-block shadow-neo">Adding basic styling and testing layouts.</p>
            </div>
        </div>
    </Section>

    <Section title="Style Guide & UI Elements" class="bg-brand-yellow border-y-4 border-black relative overflow-hidden">
        <div class="absolute inset-0 bg-grid-pattern"></div>
        <div class="relative z-10">
            <div class="mb-12 bg-white p-6 border-4 border-black shadow-neo inline-block transform rotate-1">
                <p class="text-black text-xl font-bold leading-relaxed">
                    Our visual identity was crafted to be engaging, accessible, and playful to support the gamified nature of Gradventure.
                </p>
            </div>
            
            <!-- Placeholder for Typography, Colors, Components -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
                <div class="border-4 border-black p-8 bg-white shadow-neo transform -rotate-1 hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-neo-none transition-all">
                    <h4 class="font-black text-2xl font-display uppercase mb-4 border-b-4 border-brand-pink pb-2 inline-block">Typography</h4>
                    <p class="text-black font-bold bg-gray-200 border-2 border-black px-2 py-1 inline-block">(Fonts used)</p>
                </div>
                <div class="border-4 border-black p-8 bg-white shadow-neo transform rotate-1 hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-neo-none transition-all">
                    <h4 class="font-black text-2xl font-display uppercase mb-4 border-b-4 border-brand-accent pb-2 inline-block">Color Palette</h4>
                    <p class="text-black font-bold bg-gray-200 border-2 border-black px-2 py-1 inline-block">(Primary & Secondary)</p>
                </div>
                <div class="border-4 border-black p-8 bg-white shadow-neo transform -rotate-1 hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-neo-none transition-all">
                    <h4 class="font-black text-2xl font-display uppercase mb-4 border-b-4 border-brand-green pb-2 inline-block">Iconography</h4>
                    <p class="text-black font-bold bg-gray-200 border-2 border-black px-2 py-1 inline-block">(Icon style used)</p>
                </div>
            </div>
        </div>
    </Section>
</Layout>