---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';

const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith('/') ? base : `${base}/`;
---

<Layout title="HCI Portfolio | Home">
    <Hero
        title="Gradventure"
        subtitle="A process portfolio documenting the iterative design journey of our game-based study abroad application."
        tag="Course Project 2026"
        primaryAction={{ text: "View Research", href: `${normalizedBase}research/` }}
        secondaryAction={{ text: "View Prototypes", href: `${normalizedBase}prototypes/` }}
    />

    <Section title="Design Journey" subtitle="From initial concepts to final validation.">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="bg-brand-yellow p-4 border-4 border-black shadow-neo transform -rotate-1 hover:rotate-0 transition-transform">
                <Card
                    title="Brainstorming"
                    body="Problem definition and user personas."
                    href={`${normalizedBase}brainstorm/`}
                    icon="💡"
                />
            </div>
            <div class="bg-brand-pink p-4 border-4 border-black shadow-neo transform rotate-1 hover:rotate-0 transition-transform">
                <Card 
                    title="User Research" 
                    body="Stakeholder consultation, survey & interview results, user journey maps, and key requirements."
                    href={`${normalizedBase}research/`}
                    icon="🔍"
                />
            </div>
            <div class="bg-brand-green p-4 border-4 border-black shadow-neo transform -rotate-2 hover:rotate-0 transition-transform">
                <Card 
                    title="Design Journey" 
                    body="Design iterations, wireframing, and UI styling decisions."
                    href={`${normalizedBase}design/`}
                    icon="🎨"
                />
            </div>
            <div class="bg-brand-cyan p-4 border-4 border-black shadow-neo transform rotate-2 hover:rotate-0 transition-transform">
                <Card 
                    title="Prototypes" 
                    body="Low-fidelity to high-fidelity interactive prototypes."
                    href={`${normalizedBase}prototypes/`}
                    icon="📱"
                />
            </div>
            <div class="bg-brand-orange p-4 border-4 border-black shadow-neo transform -rotate-1 hover:rotate-0 transition-transform">
                <Card 
                    title="Evaluation" 
                    body="User testing sessions, feedback analysis, and design refinements."
                    href={`${normalizedBase}evaluation/`}
                    icon="🧪"
                />
            </div>
            <div class="bg-[#A8A6FF] p-4 border-4 border-black shadow-neo transform rotate-1 hover:rotate-0 transition-transform">
                <Card
                    title="About The Team"
                    body="Meet the designers and developers behind this project."
                    href={`${normalizedBase}team/`}
                    icon="👥"
                />
            </div>
        </div>
    </Section>

    <Section class="bg-brand-yellow border-y-4 border-black relative overflow-hidden">
        <div class="absolute inset-0 bg-grid-pattern"></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10">
            <div class="bg-white border-4 border-black p-8 shadow-neo-lg">
                <h2 class="text-4xl font-black tracking-tighter mb-6 font-display uppercase">The Mission</h2>
                <p class="text-black font-bold leading-relaxed mb-6 text-lg">
                    <span class="bg-black text-white px-2 py-1 mr-1">GRADVENTURE</span> is an engaging web application that gamifies the study abroad preparation process for students. By combining educational content with game mechanics, we aim to make learning about international education accessible and fun.
                </p>
                <a href={`${normalizedBase}brainstorm/`} class="inline-block border-b-4 border-black pb-1 hover:bg-brand-accent hover:text-white hover:border-transparent transition-all font-display font-black text-xl">Read our Problem Statement →</a>
            </div>
                <div class="aspect-video bg-white border-4 border-black flex items-center justify-center relative overflow-hidden shadow-neo-lg">
                    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
                    <span class="font-mono font-bold text-black bg-brand-pink px-4 py-2">PROJECT_PREVIEW.img</span>
                </div>
            </div>
        </Section>
</Layout>
