---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
---

<Layout title="Prototypes | HCI Portfolio">
    <PageHeader 
        title="Prototypes" 
        description="Interactive demonstrations of the application."
    />

    <Section title="Interactive Prototype">
        <div class="w-full aspect-video bg-brand-yellow border-4 border-black flex flex-col items-center justify-center relative overflow-hidden group shadow-neo-lg transform -rotate-1 hover:rotate-0 transition-transform">
             <div class="absolute inset-0 bg-grid-pattern"></div>
            <span class="font-mono font-bold text-black text-2xl mb-8 bg-white border-4 border-black px-6 py-3 shadow-neo transform rotate-2 group-hover:-rotate-2 transition-transform">FIGMA_EMBED_OR_VIDEO</span>
            <button class="btn btn-primary text-xl px-12 py-6 relative z-10 hover:bg-white hover:text-black">LAUNCH PROTOTYPE</button>
        </div>
    </Section>

    <Section title="Key Features" class="bg-brand-pink border-y-4 border-black relative overflow-hidden">
        <div class="absolute inset-0 bg-grid-pattern"></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 relative z-10">
            <div class="bg-white border-4 border-black p-8 shadow-neo transform rotate-1 hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-neo-none transition-all">
                <h3 class="text-3xl font-black text-black mb-6 font-display uppercase border-b-4 border-black pb-2 inline-block">Gamified Dashboard</h3>
                <p class="text-black font-bold text-lg mb-8 leading-relaxed border-l-4 border-brand-accent pl-4 py-1">
                    Students can track their progress through levels, earning badges and rewards for completing tasks.
                </p>
                <div class="aspect-video bg-brand-cyan border-4 border-black shadow-neo flex items-center justify-center">
                    <span class="text-black font-bold uppercase bg-white border-2 border-black px-2 py-1">Screenshot</span>
                </div>
            </div>
            <div class="bg-white border-4 border-black p-8 shadow-neo transform -rotate-1 hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-neo-none transition-all">
                <h3 class="text-3xl font-black text-black mb-6 font-display uppercase border-b-4 border-black pb-2 inline-block">Interactive Map</h3>
                <p class="text-black font-bold text-lg mb-8 leading-relaxed border-l-4 border-brand-yellow pl-4 py-1">
                    A visual exploration tool for discovering universities and cultural information.
                </p>
                <div class="aspect-video bg-brand-green border-4 border-black shadow-neo flex items-center justify-center">
                    <span class="text-black font-bold uppercase bg-white border-2 border-black px-2 py-1">Screenshot</span>
                </div>
            </div>
        </div>
    </Section>
</Layout>
