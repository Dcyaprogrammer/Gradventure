---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import TeamMember from '../components/TeamMember.astro';

// Team member data
const teamMembers = [
	{
		name: "Chengyang Du",
		id: "2360818",
		avatar: "avatar-chengyang.jpg",
		role: "Team Member",
		bio: "Contributing to the design and development of Gradventure, focusing on creating an engaging experience for students preparing for study abroad applications.",
		skills: ["Design", "Development", "Research"],
        color: "bg-brand-pink"
	},
	{
		name: "Gulong Sun",
		id: "2362272",
		avatar: "avatar-gulong.jpg",
		role: "Team Member",
		bio: "I am a third-year undergraduate student majoring in ICS. I have taken several programming and algorithms courses in the past. I am really looking forward to taking CPT208 and collaborating with everyone in the class.",
		skills: ["Design", "Development", "Research"],
        color: "bg-brand-yellow"
	},
	{
		name: "Yanhan Jin",
		id: "2362139",
		avatar: "avatar-yanhan.jpg",
		role: "Team Member",
		bio: "I am a third-year undergraduate student at Xi'an Jiaotong-Liverpool University, majoring in Information and Computing Science. During my academic journey, I have gained experience in programming, data processing, and algorithm design. I am excited to collaborate with my team members and contribute to meaningful work together.",
		skills: ["Design", "Development", "Research"],
        color: "bg-brand-green"
	},
	{
		name: "Yixuan Zheng",
		id: "2362357",
		avatar: "avatar-yixuan.jpg",
		role: "Team Member",
		bio: "As a third-year ICS student at Xi'an Jiaotong-Liverpool University, I'm particularly interested in how computing can be applied to real-world problems. I've explored areas like data analysis and machine learning, and I enjoy the process of turning data into useful insights. I'm looking forward to learning from my teammates and contributing to our work together.",
		skills: ["Design", "Development", "Research"],
        color: "bg-brand-cyan"
	}
];
---

<Layout title="HCI Portfolio | Team">
	<PageHeader
		title="Meet The Team"
		description="The four designers and developers behind Gradventure."
	/>

	<Section title="Our Team">
		<div class="mb-12 bg-white p-6 border-4 border-black shadow-neo inline-block transform -rotate-1">
            <p class="text-black text-xl font-bold leading-relaxed">
                We are a group of four students with diverse backgrounds in design, development, and education.
                Together, we're building <span class="bg-black text-white px-2 py-1 uppercase tracking-widest">Gradventure</span> — an engaging platform
                to help students navigate the study abroad application process through gamification.
            </p>
        </div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
			{teamMembers.map((member, i) => (
				<div class={`${member.color} p-4 border-4 border-black shadow-neo-lg transform ${i % 2 === 0 ? 'rotate-1' : '-rotate-1'} hover:rotate-0 hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-neo-none transition-all`}>
					<TeamMember {...member} />
				</div>
			))}
		</div>
	</Section>

	<Section title="Roles & Responsibilities" class="bg-brand-orange border-y-4 border-black relative overflow-hidden">
        <div class="absolute inset-0 bg-grid-pattern"></div>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
			<div class="border-4 border-black p-8 bg-white shadow-neo transform rotate-1">
				<h3 class="text-black font-black font-display text-2xl uppercase mb-4 border-b-4 border-black pb-2 inline-block">Design</h3>
				<p class="text-black font-bold text-lg leading-relaxed border-l-4 border-brand-pink pl-4">
					User research, persona development, wireframing, prototyping, visual design,
					and ensuring accessibility throughout the application.
				</p>
			</div>
			<div class="border-4 border-black p-8 bg-white shadow-neo transform -rotate-1">
				<h3 class="text-black font-black font-display text-2xl uppercase mb-4 border-b-4 border-black pb-2 inline-block">Development</h3>
				<p class="text-black font-bold text-lg leading-relaxed border-l-4 border-brand-accent pl-4">
					Frontend implementation with modern frameworks, backend architecture,
					database design, API development, and deployment.
				</p>
			</div>
			<div class="border-4 border-black p-8 bg-white shadow-neo transform -rotate-1">
				<h3 class="text-black font-black font-display text-2xl uppercase mb-4 border-b-4 border-black pb-2 inline-block">Content</h3>
				<p class="text-black font-bold text-lg leading-relaxed border-l-4 border-brand-yellow pl-4">
					Curriculum development, gamification strategy, learning path design,
					and ensuring educational content is accurate and engaging.
				</p>
			</div>
			<div class="border-4 border-black p-8 bg-white shadow-neo transform rotate-1">
				<h3 class="text-black font-black font-display text-2xl uppercase mb-4 border-b-4 border-black pb-2 inline-block">Testing</h3>
				<p class="text-black font-bold text-lg leading-relaxed border-l-4 border-brand-green pl-4">
					User testing coordination, feedback analysis, quality assurance,
					and iterative improvements based on real user data.
				</p>
			</div>
		</div>
	</Section>

	<Section title="Project Timeline">
		<div class="relative max-w-4xl mx-auto">
			<!-- Timeline line -->
			<div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-[4px] bg-black md:-translate-x-[2px]"></div>

			<div class="space-y-12">
				<!-- Phase 1 -->
				<div class="relative flex items-center md:justify-center">
					<div class="absolute left-8 md:left-1/2 w-6 h-6 bg-brand-pink border-4 border-black md:-translate-x-1/2 rounded-full z-10"></div>
					<div class="ml-20 md:ml-0 md:w-1/2 md:pr-16 md:text-right w-full">
						<span class="bg-white text-black font-bold px-2 py-1 text-sm uppercase border-2 border-black inline-block mb-2 shadow-neo">Weeks 1-3</span>
						<h3 class="text-black font-black text-2xl uppercase font-display border-b-4 border-black pb-1 inline-block">Research & Ideation</h3>
						<p class="text-black font-bold text-lg mt-4 bg-white border-2 border-black p-4 shadow-neo">Problem definition, user research, competitive analysis, initial concepts</p>
					</div>
				</div>

				<!-- Phase 2 -->
				<div class="relative flex items-center md:justify-center md:flex-row-reverse">
					<div class="absolute left-8 md:left-1/2 w-6 h-6 bg-brand-yellow border-4 border-black md:-translate-x-1/2 rounded-full z-10"></div>
					<div class="ml-20 md:ml-0 md:w-1/2 md:pl-16 w-full">
						<span class="bg-white text-black font-bold px-2 py-1 text-sm uppercase border-2 border-black inline-block mb-2 shadow-neo">Weeks 4-6</span>
						<h3 class="text-black font-black text-2xl uppercase font-display border-b-4 border-black pb-1 inline-block">Design & Prototyping</h3>
						<p class="text-black font-bold text-lg mt-4 bg-white border-2 border-black p-4 shadow-neo">Information architecture, wireframes, low-fi and hi-fi prototypes</p>
					</div>
				</div>

				<!-- Phase 3 -->
				<div class="relative flex items-center md:justify-center">
					<div class="absolute left-8 md:left-1/2 w-6 h-6 bg-brand-green border-4 border-black md:-translate-x-1/2 rounded-full z-10"></div>
					<div class="ml-20 md:ml-0 md:w-1/2 md:pr-16 md:text-right w-full">
						<span class="bg-white text-black font-bold px-2 py-1 text-sm uppercase border-2 border-black inline-block mb-2 shadow-neo">Weeks 7-9</span>
						<h3 class="text-black font-black text-2xl uppercase font-display border-b-4 border-black pb-1 inline-block">User Testing</h3>
						<p class="text-black font-bold text-lg mt-4 bg-white border-2 border-black p-4 shadow-neo">Usability testing sessions, feedback collection, iterative improvements</p>
					</div>
				</div>

				<!-- Phase 4 -->
				<div class="relative flex items-center md:justify-center md:flex-row-reverse">
					<div class="absolute left-8 md:left-1/2 w-6 h-6 bg-brand-cyan border-4 border-black md:-translate-x-1/2 rounded-full z-10"></div>
					<div class="ml-20 md:ml-0 md:w-1/2 md:pl-16 w-full">
						<span class="bg-white text-black font-bold px-2 py-1 text-sm uppercase border-2 border-black inline-block mb-2 shadow-neo">Weeks 10-12</span>
						<h3 class="text-black font-black text-2xl uppercase font-display border-b-4 border-black pb-1 inline-block">Implementation</h3>
						<p class="text-black font-bold text-lg mt-4 bg-white border-2 border-black p-4 shadow-neo">Development of the web application, content integration, launch preparation</p>
					</div>
				</div>

				<!-- Phase 5 -->
				<div class="relative flex items-center md:justify-center">
					<div class="absolute left-8 md:left-1/2 w-6 h-6 bg-brand-accent border-4 border-black md:-translate-x-1/2 rounded-full z-10"></div>
					<div class="ml-20 md:ml-0 md:w-1/2 md:pr-16 md:text-right w-full">
						<span class="bg-white text-black font-bold px-2 py-1 text-sm uppercase border-2 border-black inline-block mb-2 shadow-neo">Weeks 13-15</span>
						<h3 class="text-black font-black text-2xl uppercase font-display border-b-4 border-black pb-1 inline-block">Final Delivery</h3>
						<p class="text-black font-bold text-lg mt-4 bg-white border-2 border-black p-4 shadow-neo">Final testing, documentation, portfolio completion, project presentation</p>
					</div>
				</div>
			</div>
		</div>
	</Section>
</Layout>
